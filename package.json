    "release:check": "bash ./scripts/check-release-version.sh"
  },
  "devDependencies": {
    "@topogram/cli": "^0.3.43",
    "@topogram/generator-hono-api": "0.2.6",
    "@topogram/generator-postgres-db": "0.1.6",
    "@topogram/generator-sveltekit-web": "0.1.14"
  }
}
